<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.sgc.controller.MainController">
    <top>
        <MenuBar>
            <Menu text="Archivo">
                <MenuItem text="Exportar PDF" onAction="#handleExportPDF"/>
                <MenuItem text="Exportar CSV" onAction="#handleExportCSV"/>
                <SeparatorMenuItem/>
                <MenuItem text="Salir" onAction="#handleExit"/>
            </Menu>
        </MenuBar>
    </top>
    <center>
        <TabPane>
            <Tab text="Alumnos" closable="false">
                <VBox spacing="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <HBox spacing="10">
                        <TextField fx:id="txtNombreAlumno" promptText="Nombre"/>
                        <TextField fx:id="txtEmailAlumno" promptText="Email"/>
                        <Button text="Agregar" onAction="#handleAddAlumno"/>
                    </HBox>
                    <TableView fx:id="tblAlumnos" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colIdAlumno" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="colNombreAlumno" text="Nombre" prefWidth="200"/>
                            <TableColumn fx:id="colEmailAlumno" text="Email" prefWidth="200"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="Materias" closable="false">
                <VBox spacing="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <HBox spacing="10">
                        <TextField fx:id="txtNombreMateria" promptText="Nombre Materia"/>
                        <Button text="Agregar" onAction="#handleAddMateria"/>
                    </HBox>
                    <TableView fx:id="tblMaterias" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colIdMateria" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="colNombreMateria" text="Nombre" prefWidth="300"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="Calificaciones" closable="false">
                <VBox spacing="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <GridPane hgap="10" vgap="10">
                        <Label text="Alumno:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="cmbAlumno" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>
                        
                        <Label text="Materia:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="cmbMateria" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="200"/>
                        
                        <Label text="Nota:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtNota" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        
                        <Label text="Periodo:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtPeriodo" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                        
                        <Button text="Registrar" onAction="#handleAddCalificacion" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                    </GridPane>
                    <TableView fx:id="tblCalificaciones" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colCalAlumno" text="Alumno" prefWidth="150"/>
                            <TableColumn fx:id="colCalMateria" text="Materia" prefWidth="150"/>
                            <TableColumn fx:id="colCalNota" text="Nota" prefWidth="80"/>
                            <TableColumn fx:id="colCalPeriodo" text="Periodo" prefWidth="100"/>
                            <TableColumn fx:id="colCalEstado" text="Estado" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
