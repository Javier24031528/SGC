<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.sgc.controller.LoginController"
      style="-fx-background-color: #f4f4f4;">
    
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Inicio de Sesión SGC">
        <font>
            <Font name="System Bold" size="24"/>
        </font>
    </Label>

    <GridPane vgap="10" hgap="10" alignment="CENTER">
        <Label text="Usuario:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtUsername" promptText="Ingrese su usuario" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <Label text="Contraseña:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <PasswordField fx:id="txtPassword" promptText="Ingrese su contraseña" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>

    <Button text="Ingresar" onAction="#handleLogin" prefWidth="100" 
            style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>

    <Label text="Usuario: admin / Pass: admin123" style="-fx-text-fill: gray;"/>
</VBox>
